                    }
                    h2 {
                        font-size: 14pt;
                        color: #365F91;
                        margin-top: 20pt;
                        margin-bottom: 12pt;
                        font-weight: bold;
                        border-bottom: 2px solid #365F91;
                        padding-bottom: 4px;
                    }
                    p {
                        text-align: justify;
                        margin-bottom: 12pt;
                    }
                    ul {
                        margin-bottom: 12pt;
                        padding-left: 24px;
                    }
                    li {
                        text-align: justify;
                        margin-bottom: 6pt;
                    }
